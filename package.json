{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "npx expo start --localhost",
    "web": "npx expo start --web --localhost",
    "expo:dev": "npx expo start --localhost",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "npx expo export",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "build:prod": "npm run server:build && npm run expo:static:build",
    "serve": "npm run build:prod && npm run server:prod",
    "db:push": "drizzle-kit push",
    "start": "npx expo start",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix"
  },
  "dependencies": {
    "@expo/cli": "^55.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@ungap/structured-clone": "^1.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.1",
    "expo": "^55.0.5",
    "expo-blur": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.11",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.19.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "stripe": "^20.4.0",
    "stripe-replit-sync": "^1.0.0",
    "tsx": "^4.21.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@expo/ngrok": "^4.1.3",
    "@types/express": "^5.0.6",
    "@types/react": "~19.2.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~55.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}