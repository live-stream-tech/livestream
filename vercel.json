{
  "framework": null,
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": { "maxDuration": 30 },
    "api/[...path].ts": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api(/|$)).*)", "destination": "/index.html" }
  ]
}