{
  "framework": null,
  "buildCommand": "npx expo export --platform web && node scripts/inject-sw-version.js && cp public/favi.png dist/favi.png",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/healthcheck", "destination": "/api/healthcheck" },
    { "source": "/api/auth/line-callback", "destination": "/api/auth/line-callback" },
    { "source": "/api/auth/line", "destination": "/api/auth/line" },
    { "source": "/api/(.*)", "destination": "/api/[...path]" }
  ]
}
