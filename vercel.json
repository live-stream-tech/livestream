{
  "framework": null,
  "buildCommand": "npx expo export --platform web && node scripts/inject-sw-version.js",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
