# Database (required for API)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# LINE Login (required for LINE login)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=https://your-app.vercel.app/api/auth/callback/line
FRONTEND_URL=https://your-app.vercel.app

# JWT (required in production)
SESSION_SECRET=your-random-secret-at-least-32-chars

# Frontend: API base URL (set in Vercel for static build)
EXPO_PUBLIC_DOMAIN=https://your-app.vercel.app

# Optional: Stripe
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
